// Secrets.xcconfig
// IMPORTANT: Do NOT commit this file to git!
// Copy this template to Secrets.xcconfig and fill in your values.

// ==========================================
// Development Team
// ==========================================
// Find your Team ID at: https://developer.apple.com/account -> Membership
DEVELOPMENT_TEAM = YOUR_TEAM_ID

// ==========================================
// Google Sign In
// ==========================================
// Get these from Google Cloud Console:
// 1. Go to https://console.cloud.google.com
// 2. Create/select project
// 3. Enable Google Calendar API and Google Tasks API
// 4. Create OAuth 2.0 credentials (iOS type)
// 5. Use Bundle ID: com.kiro.app

// Your Google OAuth Client ID (e.g., 123456789-abc.apps.googleusercontent.com)
GOOGLE_CLIENT_ID = YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

// Reversed Client ID for URL scheme (e.g., com.googleusercontent.apps.123456789-abc)
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.YOUR_GOOGLE_CLIENT_ID

// ==========================================
// Supabase
// ==========================================
// Get these from Supabase Dashboard:
// 1. Go to https://supabase.com
// 2. Create/select project
// 3. Go to Settings -> API

// Your Supabase project URL (e.g., https://abcdefgh.supabase.co)
// IMPORTANT: xcconfig treats `//` as the start of a line comment, so
// `SUPABASE_URL = https://abc.supabase.co` silently truncates to `https:`.
// Use `$()` (an empty variable expansion) between `:` and `//` to break the
// `//` token apart. The runtime sees the full URL after expansion.
SUPABASE_URL = https:$()//YOUR_PROJECT.supabase.co

// Your Supabase anon/public key
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY

// ==========================================
// AI provider — chat completions (companion text, screensaver, summaries)
// ==========================================
// Bearer key sent to OPENAI_BASE_URL. Default provider is OpenRouter:
OPENROUTER_API_KEY = YOUR_OPENROUTER_API_KEY
// Optional: override base URL + model to use an OpenAI-compatible gateway instead
// of OpenRouter (e.g. opencodeapi -> gpt-5.5). Leave both empty for OpenRouter.
// xcconfig `//` gotcha: use the `$()` sentinel in the URL (see SUPABASE_URL above).
// OPENAI_BASE_URL = https:$()//console.opencodeapi.com/v1
// OPENAI_MODEL = gpt-5.5
// Optional FALLBACK: when the primary provider errors, the app fails over to OpenRouter
// (gpt-oss-120b) using FALLBACK_API_KEY — transparently logged. Empty = no fallback.
// FALLBACK_API_KEY = YOUR_OPENROUTER_API_KEY

// ==========================================
// Notion Integration (Optional)
// ==========================================
// Get these from https://www.notion.so/my-integrations
// 1. Create a new integration (Public type)
// 2. Set redirect URI to: kirole://notion-callback
// 3. Configure the OAuth secret only on the Supabase Edge Function host
// 4. Rebuild the app after updating this value so BuildSecrets is regenerated
NOTION_OAUTH_CLIENT_ID = YOUR_NOTION_OAUTH_CLIENT_ID

// ==========================================
// Taskade Integration (Optional)
// ==========================================
// Get these from Taskade Developer Settings
// 1. Register a new OAuth application
// 2. Set redirect URI to: kirole://taskade-callback
// 3. Configure the OAuth secret only on the Supabase Edge Function host
// 4. Rebuild the app after updating this value so BuildSecrets is regenerated
TASKADE_OAUTH_CLIENT_ID = YOUR_TASKADE_OAUTH_CLIENT_ID
