require "spaceship"

default_platform(:ios)

BUNDLE_ID = "com.kirole.app"

platform :ios do
  # Usage:
  #   bundle exec fastlane ios notes text:"说明内容"
  #   bundle exec fastlane ios notes file:fastlane/release_notes.txt
  desc "Update TestFlight What to Test for the latest build"
  lane :notes do |options|
    text = resolve_notes(options)

    token = asc_token
    Spaceship::ConnectAPI.token = token

    app   = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    build = latest_build(app)

    app_version = build.pre_release_version ? build.pre_release_version.version : "?"
    UI.message("Updating notes for v#{app_version} (build #{build.version})")
    update_localizations(build, text)
    UI.success("Done — v#{app_version}(#{build.version}) notes updated")
  end
end

# ── helpers ──────────────────────────────────────────────────────────────────

def resolve_notes(options)
  if options[:file]
    path = File.expand_path(options[:file])
    UI.user_error!("File not found: #{path}") unless File.exist?(path)
    File.read(path).strip
  elsif options[:text]
    options[:text].strip
  else
    UI.user_error!('Pass text:"..." or file:"path/to/notes.txt"')
  end
end

def asc_token
  Spaceship::ConnectAPI::Token.create(
    key_id:    ENV.fetch("ASC_KEY_ID")   { UI.user_error!("ASC_KEY_ID not set") },
    issuer_id: ENV.fetch("ASC_ISSUER_ID") { UI.user_error!("ASC_ISSUER_ID not set") },
    filepath:  ENV.fetch("ASC_KEY_PATH") { UI.user_error!("ASC_KEY_PATH not set") }
  )
end

def latest_build(app)
  builds = Spaceship::ConnectAPI::Build.all(
    app_id: app.id,
    sort:   "-uploadedDate",
    limit:  1
  )
  UI.user_error!("No builds found for #{BUNDLE_ID}") if builds.empty?
  builds.first
end

def update_localizations(build, text)
  client = Spaceship::ConnectAPI
  locs = client.get_beta_build_localizations(filter: { build: build.id, locale: "zh-Hans" })
            .all_pages.flat_map(&:to_models)

  if locs.empty?
    client.post_beta_build_localizations(
      build_id:   build.id,
      attributes: { locale: "zh-Hans", whatsNew: text }
    )
  else
    client.patch_beta_build_localizations(
      localization_id: locs.first.id,
      attributes:      { whatsNew: text }
    )
  end
end
