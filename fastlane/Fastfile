require "spaceship"

default_platform(:ios)

BUNDLE_ID = "com.kirole.app"

platform :ios do
  desc "Full pipeline: increment build → archive → upload → set notes → distribute to external groups"
  lane :release do |options|
    en_text = resolve_notes(options)

    # 1. Bump build number
    new_build = increment_build_number(xcodeproj: "Kirole.xcodeproj")
    UI.message("▶ Build number → #{new_build}")

    # 2. Archive + export IPA (Automatic Signing switches to Distribution cert)
    gym(
      workspace:     "Kirole.xcworkspace",
      scheme:        "Kirole",
      export_method: "app-store"
    )

    # 3. Upload to TestFlight and wait for Apple processing
    api_key = app_store_connect_api_key(
      key_id:       ENV.fetch("ASC_KEY_ID")   { UI.user_error!("ASC_KEY_ID not set") },
      issuer_id:    ENV.fetch("ASC_ISSUER_ID") { UI.user_error!("ASC_ISSUER_ID not set") },
      key_filepath: ENV.fetch("ASC_KEY_PATH")  { UI.user_error!("ASC_KEY_PATH not set") }
    )
    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: false,
      distribute_external:               false
    )

    # 4. Set localized notes + distribute via Spaceship
    Spaceship::ConnectAPI.token = asc_token
    app   = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    build = latest_build(app)

    upsert_localization(build, "en-US", en_text)
    UI.message("✓ English notes set")

    zh_text = options[:zh_text]
    if zh_text.nil? && options[:zh_file]
      path = File.expand_path(options[:zh_file])
      zh_text = File.read(path).strip if File.exist?(path)
    end
    if zh_text && !zh_text.empty?
      upsert_localization(build, "zh-Hans", zh_text)
      UI.message("✓ Chinese notes set")
    end

    distribute_to_external_groups(app, build)
    UI.success("Done — build #{new_build} released to external testers")
  end

  desc "Update TestFlight What to Test notes only (zh-Hans)"
  lane :notes do |options|
    text = resolve_notes(options)

    token = asc_token
    Spaceship::ConnectAPI.token = token

    app   = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    build = latest_build(app)

    app_version = build.pre_release_version ? build.pre_release_version.version : "?"
    UI.message("Updating notes for v#{app_version} (build #{build.version})")
    upsert_localization(build, "zh-Hans", text)
    UI.success("Done — v#{app_version}(#{build.version}) notes updated")
  end

  desc "Finish a release that uploaded+processed OK but died at external distribution (e.g. SSL EOF after Internal distribution). Idempotent: notes upsert + beta-review submit both skip if already done. Operates on the latest build — no archive/upload, no build bump."
  lane :finish_external do |options|
    en_text = resolve_notes(options)
    Spaceship::ConnectAPI.token = asc_token
    app   = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    build = latest_build(app)
    UI.message("▶ Finishing build #{build.version} — en notes + external distribution + beta review")
    upsert_localization(build, "en-US", en_text)
    UI.success("✓ English notes set")
    distribute_to_external_groups(app, build)
    UI.success("Done — build #{build.version} distributed to external testers")
  end

  desc "Verify the latest TestFlight build actually landed: processing state + beta review state. Run after every release — a fastlane 'Done' line alone is not proof (process can be killed mid-upload)."
  lane :status do
    Spaceship::ConnectAPI.token = asc_token
    app   = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    build = latest_build(app)
    app_version = build.pre_release_version ? build.pre_release_version.version : "?"
    UI.message("Latest build: v#{app_version} (#{build.version}), uploaded #{build.uploaded_date}")
    UI.message("processingState: #{build.processing_state}")
    detail = Spaceship::ConnectAPI.get_build_beta_details(filter: { build: build.id }).first
    if detail
      UI.message("internalBuildState: #{detail.internal_build_state}")
      UI.message("externalBuildState: #{detail.external_build_state}")
    end
    UI.success("Done — build #{build.version}: #{build.processing_state} / external=#{detail&.external_build_state}")
  end
end

# ── helpers ──────────────────────────────────────────────────────────────────

def resolve_notes(options)
  if options[:file]
    path = File.expand_path(options[:file])
    UI.user_error!("File not found: #{path}") unless File.exist?(path)
    File.read(path).strip
  elsif options[:text]
    options[:text].strip
  else
    UI.user_error!('Pass text:"..." or file:"path/to/notes.txt"')
  end
end

def asc_token
  Spaceship::ConnectAPI::Token.create(
    key_id:    ENV.fetch("ASC_KEY_ID")   { UI.user_error!("ASC_KEY_ID not set") },
    issuer_id: ENV.fetch("ASC_ISSUER_ID") { UI.user_error!("ASC_ISSUER_ID not set") },
    filepath:  ENV.fetch("ASC_KEY_PATH")  { UI.user_error!("ASC_KEY_PATH not set") }
  )
end

def latest_build(app)
  builds = Spaceship::ConnectAPI::Build.all(
    app_id: app.id,
    sort:   "-uploadedDate",
    limit:  1
  )
  UI.user_error!("No builds found for #{BUNDLE_ID}") if builds.empty?
  builds.first
end

def upsert_localization(build, locale, text)
  client = Spaceship::ConnectAPI
  locs = client.get_beta_build_localizations(filter: { build: build.id, locale: locale })
               .all_pages.flat_map(&:to_models)
  if locs.empty?
    client.post_beta_build_localizations(
      build_id:   build.id,
      attributes: { locale: locale, whatsNew: text }
    )
  else
    client.patch_beta_build_localizations(
      localization_id: locs.first.id,
      attributes:      { whatsNew: text }
    )
  end
end

def distribute_to_external_groups(app, build)
  client     = Spaceship::ConnectAPI
  all_groups = client.get_beta_groups(filter: { app: app.id })
                     .all_pages.flat_map(&:to_models)
  external   = all_groups.reject(&:is_internal_group)

  if external.empty?
    UI.important("No external beta groups found — skipping distribution")
    return
  end

  UI.message("Adding to external groups: #{external.map(&:name).join(', ')}")
  client.add_beta_groups_to_build(
    build_id:       build.id,
    beta_group_ids: external.map(&:id)
  )
  UI.message("✓ Added to external groups")

  # Submit for Beta App Review — REQUIRED for external testers (incl. the public
  # link) to actually receive the build. Without it the build stays NO_SUBMISSION
  # / "Ready to Submit" and the public link keeps serving the last APPROVED build
  # (this is exactly why testers were stuck on 543). A build of an
  # already-approved version string is auto-approved immediately.
  submit_for_beta_review(client, build)
end

def submit_for_beta_review(client, build)
  existing = client.get_beta_app_review_submissions(filter: { build: build.id })
                   .all_pages.flat_map(&:to_models)
  unless existing.empty?
    UI.message("Beta review already exists: #{existing.map(&:beta_review_state).join(', ')}")
    return
  end
  client.post_beta_app_review_submissions(build_id: build.id)
  UI.success("✓ Submitted for external Beta App Review")
rescue => e
  UI.important("⚠ Beta review submission failed — submit manually in ASC: #{e.message}")
end
